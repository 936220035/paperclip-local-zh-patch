+
+const ignoredTags = new Set(["SCRIPT", "STYLE", "TEXTAREA", "INPUT", "CODE", "PRE"]);
+
+function translateText(value: string): string {
+  const compact = value.replace(/\s+/g, " ").trim();
+  if (!compact) return value;
+
+  const exact = exactTranslations[compact];
+  if (exact) return value.replace(compact, exact);
+
+  for (const [pattern, translate] of regexTranslations) {
+    const match = compact.match(pattern);
+    if (match) {
+      return value.replace(compact, translate(match));
+    }
+  }
+
+  let nextValue = value;
+  for (const [pattern, translate] of inlineRegexTranslations) {
+    nextValue = nextValue.replace(pattern, translate as never);
+  }
+  if (nextValue !== value) return nextValue;
+
+  return value;
+}
+
+function localizeTextNode(node: Text) {
+  const nextValue = translateText(node.nodeValue ?? "");
+  if (nextValue !== node.nodeValue) {
+    node.nodeValue = nextValue;
+  }
+}
+
+function localizeElementAttributes(element: Element) {
+  for (const name of ["title", "aria-label", "placeholder"]) {
+    const value = element.getAttribute(name);
+    if (!value) continue;
+    const translated = translateText(value);
+    if (translated !== value) element.setAttribute(name, translated);
+  }
+}
+
+function localizeNode(root: Node) {
+  if (root.nodeType === Node.TEXT_NODE) {
+    localizeTextNode(root as Text);
+    return;
+  }
+
+  if (root.nodeType !== Node.ELEMENT_NODE && root.nodeType !== Node.DOCUMENT_NODE) return;
+
+  const element = root.nodeType === Node.ELEMENT_NODE ? (root as Element) : null;
+  if (element && ignoredTags.has(element.tagName)) return;
+  if (element) localizeElementAttributes(element);
+
+  const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT | NodeFilter.SHOW_ELEMENT, {
+    acceptNode(node) {
+      if (node.nodeType === Node.ELEMENT_NODE && ignoredTags.has((node as Element).tagName)) {
+        return NodeFilter.FILTER_REJECT;
+      }
+      return NodeFilter.FILTER_ACCEPT;
+    },
+  });
+
+  let current = walker.nextNode();
+  while (current) {
+    if (current.nodeType === Node.TEXT_NODE) {
+      localizeTextNode(current as Text);
+    } else if (current.nodeType === Node.ELEMENT_NODE) {
+      localizeElementAttributes(current as Element);
+    }
+    current = walker.nextNode();
+  }
+}
+
+function installLocalizer() {
+  localizeNode(document.body);
+  document.title = translateText(document.title);
+
+  const observer = new MutationObserver((mutations) => {
+    for (const mutation of mutations) {
+      for (const node of Array.from(mutation.addedNodes)) {
+        localizeNode(node);
+      }
+      if (mutation.type === "characterData") {
+        localizeNode(mutation.target);
+      }
+      if (mutation.type === "attributes" && mutation.target instanceof Element) {
+        localizeElementAttributes(mutation.target);
+      }
+    }
+  });
+
+  observer.observe(document.body, {
+    attributes: true,
+    attributeFilter: ["title", "aria-label", "placeholder"],
+    characterData: true,
+    childList: true,
+    subtree: true,
+  });
+}
+
+if (typeof window !== "undefined") {
+  if (document.readyState === "loading") {
+    document.addEventListener("DOMContentLoaded", installLocalizer, { once: true });
+  } else {
+    installLocalizer();
+  }
+}
